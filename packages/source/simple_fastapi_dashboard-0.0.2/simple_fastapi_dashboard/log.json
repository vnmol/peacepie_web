{
    "version": 1,
    "disable_existing_loggers": true,
    "formatters": {
        "standard": {
            "format": "%(levelname)-7s %(asctime)s %(processName)-11s %(lineno)4d %(module)-16s : %(message)s"
        }
    },
    "handlers": {
        "default": {
            "level": "DEBUG",
            "formatter": "standard",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "/home/vmol/PycharmProjects/peacepie_web/logs/simple_fastapi_dashboard/log.log",
            "mode": "a",
            "maxBytes": 10485760,
            "backupCount": 5
        },
        "aiohttp": {
            "level": "DEBUG",
            "formatter": "standard",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "/home/vmol/PycharmProjects/peacepie_web/logs/simple_fastapi_dashboard/aiohttp.log",
            "mode": "a",
            "maxBytes": 10485760,
            "backupCount": 5
        },
        "uvicorn": {
            "level": "DEBUG",
            "formatter": "standard",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "/home/vmol/PycharmProjects/peacepie_web/logs/simple_fastapi_dashboard/uvicorn.log",
            "mode": "a",
            "maxBytes": 10485760,
            "backupCount": 5
        },
        "multipart": {
            "level": "DEBUG",
            "formatter": "standard",
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "/home/vmol/PycharmProjects/peacepie_web/logs/simple_fastapi_dashboard/multipart.log",
            "mode": "a",
            "maxBytes": 10485760,
            "backupCount": 5
        }
    },
    "loggers": {
        "": {
            "handlers": [
                "default"
            ],
            "level": "DEBUG",
            "propagate": false
        },
        "my.packg": {
            "handlers": [
                "default"
            ],
            "level": "DEBUG",
            "propagate": false
        },
        "aiohttp": {
            "handlers": [
                "aiohttp"
            ],
            "level": "DEBUG",
            "propagate": false
        },
        "uvicorn": {
            "handlers": [
                "uvicorn"
            ],
            "level": "DEBUG",
            "propagate": false
        },
        "python_multipart": {
            "handlers": [
                "multipart"
            ],
            "level": "DEBUG",
            "propagate": false
        },
        "__main__": {
            "handlers": [
                "default"
            ],
            "level": "DEBUG",
            "propagate": false
        }
    }
}